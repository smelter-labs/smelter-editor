{
  "expo": {
    "name": "smelter-editor-tablet",
    "slug": "smelter-editor-tablet",
    "version": "1.1.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "smeltereditortablet",
    "expo": {
      "experiments": {
        "reactCompiler": true
      }
    },
    "ios": {
      "supportsTablet": true,
      "requiresFullScreen": true,
      "bundleIdentifier": "com.smeltereditortablet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "usesCleartextTraffic": true,
      "package": "com.smeltereditortablet",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "**/libworklets.so"
              ]
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f1a",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Smelter Editor to access your camera for QR code scanning and streaming.",
          "microphonePermission": "Allow Smelter Editor to access your microphone for camera streaming."
        }
      ],
      "expo-screen-orientation"
    ]
  }
}
