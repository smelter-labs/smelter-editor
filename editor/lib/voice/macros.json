    {
      "id": "fast-transition-mode",
      "triggers": [
        "fast transition mode",
        "quick cuts mode",
        "speed up transitions"
      ],
      "description": "Applies short transition timings for snappy scene changes",
      "steps": [
        {
          "action": "SET_SWAP_DURATION",
          "params": {
            "durationMs": 250
          },
          "delayAfterMs": 200
        },
        {
          "action": "SET_SWAP_OUTGOING_ENABLED",
          "params": {
            "enabled": true
          },
          "delayAfterMs": 200
        },
        {
          "action": "SET_SWAP_FADE_OUT_DURATION",
          "params": {
            "durationMs": 150
          },
          "delayAfterMs": 200
        },
        {
          "action": "SET_SWAP_FADE_IN_DURATION",
          "params": {
            "durationMs": 200
          },
          "delayAfterMs": 0
        }
      ]
    },
