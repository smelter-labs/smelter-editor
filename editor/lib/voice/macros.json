    {
      "id": "galactic-transmission",
      "triggers": [
        "prepare galactic transmission",
        "galactic transmission",
        "star wars hologram"
      ],
      "description": "Creates a Star Wars style hologram transmission with text crawl",
      "steps": [
        {
          "action": "REMOVE_ALL_INPUTS",
          "delayAfterMs": 2000
        },
        {
          "action": "ADD_INPUT",
          "params": {
            "inputType": "mp4",
            "mp4Name": "space_ship_1.mp4"
          },
          "delayAfterMs": 500
        },
        {
          "action": "SET_LAYOUT",
          "params": {
            "layout": "grid"
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_INPUT",
          "params": {
            "inputType": "camera"
          },
          "delayAfterMs": 2000
        },
        {
          "action": "ADD_SHADER",
          "params": {
            "shader": "remove-color",
            "targetColor": "#40bb58",
            "shaderParams": { "tolerance": 0.31 }
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_SHADER",
          "params": {
            "shader": "sw-hologram",
            "shaderParams": {
              "tint_r": 0.15,
              "tint_g": 0.44,
              "tint_b": 1.0,
              "opacity": 0.79,
              "scanline_speed": 8.5,
              "jitter_x_px": 3.4,
              "glow_intensity": 0.19,
              "edge_glow_width": 0.09,
              "brightness": 3.47,
              "bloom_radius": 31.38
            }
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_INPUT",
          "params": {
            "inputType": "text",
            "text": "A long time ago\nin a galaxy far, far away...\n"
          },
          "delayAfterMs": 2000
        },
        {
          "action": "SET_TEXT_FONT_SIZE",
          "params": {
            "fontSize": 40
          },
          "delayAfterMs": 1500
        },
        {
          "action": "SET_TEXT_COLOR",
          "params": {
            "color": "#ffff00"
          },
          "delayAfterMs": 1500
        },
        {
          "action": "SET_TEXT_SCROLL_SPEED",
          "params": {
            "scrollSpeed": 80
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_SHADER",
          "params": {
            "shader": "remove-color",
            "shaderParams": { "tolerance": 0.31 }
          },
          "delayAfterMs": 1500
        },
        {
          "action": "SET_LAYOUT",
          "params": {
            "layout": "picture-on-picture"
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_SHADER",
          "params": {
            "shader": "perspective"
          },
          "delayAfterMs": 1500
        },
        {
          "action": "ADD_SHADER",
          "params": {
            "shader": "alpha-stroke",
            "shaderParams": {
              "stroke_width_px": 39,
              "softness_px": 11.5,
              "opacity": 0.4,
              "stroke_color": "#E63900"
            }
          },
          "delayAfterMs": 1500
        }
      ]
    },
