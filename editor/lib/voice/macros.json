{
  "macros": [
    {
      "id": "reset-to-camera",
      "triggers": [
        "reset to single camera input",
        "reset to camera source",
        "reset to camera",
        "only camera"
      ],
      "description": "Removes all current inputs and adds a new camera input",
      "steps": [
        {
          "action": "REMOVE_ALL_INPUTS",
          "delayAfterMs": 500
        },
        {
          "action": "ADD_INPUT",
          "params": {
            "inputType": "camera"
          },
          "delayAfterMs": 0
        }
      ]
    },
    {
